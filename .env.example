# Copy this file to .env and fill in your values.
# The .env file is git-ignored and should never be committed.

# Base URL for the LM Studio server (default: http://localhost:1234/v1)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Name of the model loaded in LM Studio (must match exactly)
LLM_MODEL=meta-llama-3-8b-instruct
